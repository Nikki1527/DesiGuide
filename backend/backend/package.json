{
  "name": "desi-guide-backend",
  "version": "1.0.0",
  "description": "Backend API for Desi Guide application with SAP HANA Cloud integration",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "test": "jest",
    "seed": "ts-node scripts/seedUsers.ts",
    "test-connection": "ts-node scripts/testConnection.ts",
    "test-connection-verbose": "ts-node scripts/testConnectionVerbose.ts",
    "test-basic": "ts-node scripts/basicConnectionTest.ts"
  },
  "keywords": [
    "express",
    "nodejs",
    "sap-hana",
    "rest-api",
    "typescript"
  ],
  "author": "Desi Guide Team",
  "license": "MIT",
  "dependencies": {
    "@sap/hana-client": "^2.21.30",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.4.5",
    "bcryptjs": "^2.4.3",
    "joi": "^17.12.2",
    "winston": "^3.11.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^9.0.8",
    "@types/jest": "^29.5.12",
    "typescript": "^5.3.3",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
